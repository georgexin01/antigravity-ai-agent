Windows Registry Editor Version 5.00

; All Files context menu
[HKEY_CLASSES_ROOT\*\shell\OpenWithAntigravity]
@="Open with Antigravity"
"Icon"="C:\\Users\\user\\AppData\\Local\\Programs\\Antigravity\\resources\\app\\resources\\win32\\default.ico"

[HKEY_CLASSES_ROOT\*\shell\OpenWithAntigravity\command]
@="powershell.exe -WindowStyle Hidden -Command \"& 'C:\\Users\\user\\AppData\\Local\\Programs\\Antigravity\\Antigravity.exe' '%1'\""

; Directory (Folder) context menu
[HKEY_CLASSES_ROOT\Directory\shell\OpenWithAntigravity]
@="Open with Antigravity"
"Icon"="C:\\Users\\user\\AppData\\Local\\Programs\\Antigravity\\resources\\app\\resources\\win32\\default.ico"

[HKEY_CLASSES_ROOT\Directory\shell\OpenWithAntigravity\command]
@="powershell.exe -WindowStyle Hidden -Command \"& 'C:\\Users\\user\\AppData\\Local\\Programs\\Antigravity\\Antigravity.exe' '%1'\""

; Directory Background context menu (right-click in empty space)
[HKEY_CLASSES_ROOT\Directory\Background\shell\OpenWithAntigravity]
@="Open with Antigravity"
"Icon"="C:\\Users\\user\\AppData\\Local\\Programs\\Antigravity\\resources\\app\\resources\\win32\\default.ico"

[HKEY_CLASSES_ROOT\Directory\Background\shell\OpenWithAntigravity\command]
@="powershell.exe -WindowStyle Hidden -Command \"& 'C:\\Users\\user\\AppData\\Local\\Programs\\Antigravity\\Antigravity.exe' '%V'\""
