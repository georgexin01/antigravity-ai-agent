# ==========================================
# ANTIGRAVITY TOTAL RESURRECTION WHITELIST (V2.0)
# ==========================================

# 1. DEFAULT: IGNORE EVERYTHING
*

# 2. WHITELIST: CORE SYSTEM FILES
!README.md
!.gitignore
!.geminiignore
!*.idx
!*.json
!*.yaml
!*.ps1

# 3. WHITELIST: VITAL DIRECTORIES (DNA & MEMORY)
!knowledge/
!knowledge/**
!skills/
!skills/**
!governance/
!governance/**
!memory/
!memory/**
!prompting/
!prompting/**

# 4. WHITELIST: STRUCTURES (NO SECRETS)
!vault/
vault/*
!vault/master_registry_template.json

# 5. BLACKLIST: NUCLEAR SECRETS & BLOAT
vault/*.enc
brain/
brain/**
conversations/
conversations/**
browser_recordings/
browser_recordings/**
html_artifacts/
html_artifacts/**
implicit/
implicit/**
tempmediaStorage/
node_modules/
.DS_Store
Thumbs.db
*.log
audit_errors.log
