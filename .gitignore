# ==========================================
# ANTIGRAVITY SOVEREIGN DISTRIBUTION FILTER
# ==========================================

# Default: Ignore Everything
*

# WHITELIST: Core Logic & AI Assets (SHAREABLE)
!README.md
!.gitignore
!.geminiignore
!route.yaml
!route.json
!skills.txt
!Sovereign_PatchDNA.ps1

# WHITELIST: Knowledge Base & Skills
!knowledge/
!knowledge/**
!skills/
!skills/**

# WHITELIST: Governance & Tools
!governance/
!governance/**
!prompting/
!prompting/**
!scratch/
!scratch/**

# ------------------------------------------
# BLACKLIST: Private Intelligence & Session Data (DO NOT SHARE)
# ------------------------------------------
brain/
brain/**
vault/
vault/*.enc
!vault/master_registry_template.json
# Whitelisted: Persistent AI Memory
!memory/
!memory/**
conversations/
conversations/**
browser_recordings/
browser_recordings/**
html_artifacts/
html_artifacts/**
implicit/
implicit/**

# Logs, Binaries & Bloat
*.log
*.pb
audit_errors.log
timestamps.json
knowledge.lock
tempmediaStorage/
node_modules/
.DS_Store
Thumbs.db

# Secrets & Local Config
mcp_config.json
*.env
.env
.env.*
installation_id
